{
  "name": "youngblood",
  "version": "0.7.10",
  "description": "A simple game development framework for web browsers.",
  "repository": "github:zsombro/youngblood",
  "main": "./dist/youngblood.mjs",
  "module": "./dist/youngblood.mjs",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/youngblood.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "shx rm -rf dist coverage",
    "build": "npm run clean && vite build",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "game",
    "development",
    "javascript",
    "html5",
    "canvas",
    "2d"
  ],
  "author": "Zsombor Zoltán Berki",
  "license": "ISC",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/matter-js": "^0.19.1",
    "@vitest/coverage-v8": "^3.2.4",
    "@typescript-eslint/eslint-plugin": "^1.7.0",
    "@typescript-eslint/parser": "^1.7.0",
    "eslint": "^5.16.0",
    "eslint-config-prettier": "^4.2.0",
    "eslint-plugin-prettier": "^3.0.1",
    "jshint": "^2.9.4",
    "jsdom": "^26.1.0",
    "prettier": "^1.17.0",
    "shx": "^0.3.2",
    "ts-node": "^8.4.1",
    "typescript": "^6.0.3",
    "vite": "^7.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "matter-js": "^0.19.0"
  }
}
